# GoHighLevel API Key
# Ve a: GHL → Settings → Company → API Keys
GHL_API_KEY=TU_API_KEY_AQUI

# GoHighLevel Location ID
# Ve a: GHL → Settings → Company → la URL tiene el ID
GHL_LOCATION_ID=TU_LOCATION_ID_AQUI
